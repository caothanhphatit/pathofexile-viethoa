{
  "name": "poe2",
  "version": "1.0.0",
  "description": "Vietnamese POE2 static reference app with PostgreSQL crawl/export tooling.",
  "main": "public/app-routes.js",
  "scripts": {
    "crawl:currency": "node scripts/crawl-currency.mjs",
    "crawl:dictionary": "node scripts/crawl-dictionary.mjs",
    "crawl:items": "node scripts/crawl-items.mjs",
    "crawl:passive-tree": "node scripts/crawl-passive-tree.mjs",
    "crawl:skill-gems": "node scripts/crawl-skill-gems.mjs",
    "crawl:all": "node scripts/crawl-skill-gems.mjs && node scripts/crawl-currency.mjs && node scripts/crawl-items.mjs && node scripts/crawl-passive-tree.mjs",
    "db:migrate": "node src/db/migrate.mjs",
    "fetch:passive-tree-icons": "node scripts/fetch-passive-tree-icons.mjs",
    "export:currency": "node scripts/export-currency.mjs",
    "export:items": "node scripts/export-items.mjs",
    "export:passive-tree": "node scripts/export-passive-tree.mjs",
    "export:skill-gems": "node scripts/export-skill-gems.mjs",
    "export:all": "node scripts/export-skill-gems.mjs && node scripts/export-currency.mjs && node scripts/export-items.mjs && node scripts/export-passive-tree.mjs",
    "translate:content": "node scripts/retranslate-content.mjs",
    "rebuild:data": "node src/db/migrate.mjs && npm run crawl:all && npm run translate:content && npm run export:all",
    "server": "node src/server/index.mjs",
    "site": "node scripts/serve-static.mjs public",
    "test": "node --test",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/styles/app.css -o ./public/dist/app.css --minify",
    "build": "npm run build:css"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
